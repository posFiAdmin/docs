              "protocol-overview/proof-of-collateral-mechanism",
              "protocol-overview/lend-borrow-market",
              "protocol-overview/leverage-loops",
              "protocol-overview/protocol-fees",
              "protocol-overview/liquidation-mechanics"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/audits",
              "resources/branding"
            ]
          }
        ]
      },
      {
        "tab": "SDK",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "sdk/installation",
