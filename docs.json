        {
          "anchor": "Community",
          "href": "https://discord.com/invite/tpccmF7wxn",
          "icon": "discord"
        },
        {
          "anchor": "Blog",
          "href": "https://medium.com/@PositionsFi",
          "icon": "newspaper"
        }
      ]
